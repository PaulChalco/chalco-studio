---

---

<section id="hero" class="hero-section">
  <!-- Background Placeholder -->
  <div class="hero-bg" data-hero-bg></div>
  <div class="hero-overlay"></div>

  <!-- Content -->
  <div class="hero-content">
    <div class="hero-label-container">
      <span class="line"></span>
      <span class="hero-label">VFX & AI ARTIST</span>
      <span class="line"></span>
    </div>

    <h1 class="hero-title">
      <span class="title-top">CHALCO</span>
      <span class="title-bottom">LABS</span>
    </h1>

    <p class="hero-subtitle">
      Creando en la intersección del movimiento, los sistemas y la forma.
    </p>

    <div class="hero-chips">
      <span class="chip"><span class="dot amber"></span>VFX</span>
      <span class="chip"><span class="dot amber"></span>COMPOSITING</span>
      <span class="chip"><span class="dot amber"></span>HOUDINI</span>
      <span class="chip"><span class="dot blue"></span>PYTHON</span>
      <span class="chip"><span class="dot blue"></span>GENAI</span>
    </div>

    <div class="hero-actions">
      <a href="#proyectos" class="cta-btn" data-cta>
        VER PROYECTOS <span class="arrow">▸</span>
      </a>
      <div class="data-block">
        <div class="data-row">
          <span class="data-label">STATUS</span>
          <span class="data-value highlight">/ DISPONIBLE</span>
        </div>
        <div class="data-row">
          <span class="data-label">FOCO</span>
          <span class="data-value">/ VFX · IA</span>
        </div>
        <div class="data-row">
          <span class="data-label">STACK</span>
          <span class="data-value">/ HOUDINI · PY</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <span class="scroll-text">SCROLL</span>
    <div class="scroll-line">
      <span class="scroll-dot"></span>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    height: 100vh;
    min-height: 680px;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-ink);
  }

  .hero-bg {
    position: absolute;
    inset: -10%;
    z-index: 0;
    background: linear-gradient(
      180deg,
      var(--color-ink) 0%,
      var(--color-surface) 100%
    );
    will-change: transform;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 11, 0.5) 0%,
      rgba(10, 10, 11, 0.8) 100%
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 0 24px;
    width: 100%;
    max-width: 1000px;
  }

  .hero-label-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-bottom: 24px;
  }

  .line {
    width: 46px;
    height: 1px;
    background: rgba(241, 233, 221, 0.4);
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.42em;
    color: var(--color-cream);
  }

  .hero-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.84;
    letter-spacing: 0.005em;
  }

  .title-top {
    display: block;
    font-size: clamp(4rem, 13vw, 13rem);
    color: var(--color-cream);
  }

  .title-bottom {
    display: block;
    font-size: clamp(4rem, 13vw, 13rem);
    background: linear-gradient(
      180deg,
      #ffd9a0,
      var(--color-amber) 55%,
      var(--color-orange)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    max-width: 680px;
    margin: 30px auto 0;
    font-family: var(--font-body);
    font-size: clamp(16px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--color-muted);
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 28px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: #cfc5b6;
    padding: 10px 17px;
    border: 1px solid rgba(241, 233, 221, 0.22);
    background: rgba(16, 15, 13, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 4px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .dot.amber {
    background-color: var(--color-amber);
  }

  .dot.blue {
    background-color: var(--color-blue);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    margin-top: 46px;
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    background: var(--color-amber);
    color: var(--color-ink);
    padding: 19px 38px;
    font-family: var(--font-display);
    font-size: 24px;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition:
      background 0.25s,
      box-shadow 0.25s;
    border-radius: 4px;
  }

  .cta-btn:hover {
    background: var(--color-orange);
    box-shadow: 0 0 40px rgba(242, 100, 17, 0.45);
  }

  .arrow {
    display: inline-block;
    transition: transform 0.25s;
  }

  .cta-btn:hover .arrow {
    transform: translateX(5px);
  }

  .data-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-align: left;
  }

  .data-row {
    display: flex;
    gap: 8px;
  }

  .data-label {
    color: #6f685e;
  }

  .data-value {
    color: #cabfb0;
  }

  .data-value.highlight {
    color: var(--color-amber);
  }

  .scroll-indicator {
    position: absolute;
    left: 50%;
    bottom: 42px;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    pointer-events: none;
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--color-muted-2);
  }

  .scroll-line {
    position: relative;
    width: 1px;
    height: 34px;
    background: rgba(241, 233, 221, 0.2);
    overflow: hidden;
  }

  .scroll-dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 10px;
    background: var(--color-amber);
    animation: scrollDotAnimation 1.8s ease-in-out infinite;
  }

  @keyframes scrollDotAnimation {
    0% {
      transform: translateY(-10px);
      opacity: 0;
    }
    30% {
      opacity: 1;
    }
    70% {
      opacity: 1;
    }
    100% {
      transform: translateY(34px);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-dot {
      animation: none;
      transform: translateY(12px);
      opacity: 0.5;
    }
    .hero-bg {
      will-change: auto;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  function initHeroAnimations() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      return;
    }

    // 1. Entrance timeline
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    // Initial opacity states set via GSAP (avoids setting opacity: 0 in global CSS if it doesn't animate)
    gsap.set(
      [
        ".hero-label-container",
        ".hero-title",
        ".hero-subtitle",
        ".hero-chips",
        ".hero-actions",
        ".scroll-indicator",
      ],
      {
        opacity: 0,
        y: 30,
      },
    );

    tl.to(".hero-label-container", { opacity: 1, y: 0, duration: 0.8 })
      .to(".hero-title", { opacity: 1, y: 0, duration: 1.0 }, "-=0.6")
      .to(".hero-subtitle", { opacity: 1, y: 0, duration: 0.8 }, "-=0.6")
      .to(".hero-chips", { opacity: 1, y: 0, duration: 0.8 }, "-=0.6")
      .to(".hero-actions", { opacity: 1, y: 0, duration: 0.8 }, "-=0.6")
      .to(".scroll-indicator", { opacity: 1, y: 0, duration: 0.8 }, "-=0.6");
  }

  // Initialize on script load and page navigation
  initHeroAnimations();
  document.addEventListener("astro:page-load", initHeroAnimations);
</script>
