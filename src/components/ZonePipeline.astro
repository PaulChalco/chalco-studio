---
const items = [
  {
    name: "ComfyUI",
    status: "planned",
    description: "Render asistido por IA, Rotoscoping, CleanUps, Relighting",
    github: "https://github.com/paulchalco",
    icon: "🧠",
  },
  {
    name: "Python para pipelines",
    status: "planned",
    description: "Automatización de procesos y scripting avanzado",
    github: "https://github.com/paulchalco",
    icon: "🐍",
  },
  {
    name: "Hugging Face",
    status: "planned",
    description: "Exploración de modelos abiertos para flujos creativos",
    github: "https://github.com/paulchalco",
    icon: "🤗",
  },
  {
    name: "NVIDIA Omniverse",
    status: "in-progress",
    description: "USD y simulación física colaborativa en tiempo real",
    github: "https://github.com/paulchalco",
    icon: "🌐",
  },
];
---

<div class="zone-pipeline-container" id="pipeline">
  <div class="pipeline-grid">
    {
      items.map((item) => (
        <!-- data-anim="scale-in" usa el mismo ScrollTrigger que motion.ts
             registra para los videos de ZoneShowreels — no crea nada nuevo -->
        <div class="pipeline-card">
          <div class="card-header">
            <span class="card-icon">{item.icon}</span>
            {item.status === "in-progress" ? (
              <span class="badge badge-in-progress">EN PROCESO</span>
            ) : (
              <span class="badge badge-planned">PRÓXIMAMENTE</span>
            )}
          </div>
          <h3 class="card-title">{item.name}</h3>
          <p class="card-desc">{item.description}</p>
          <a href={item.github} target="_blank" rel="noopener noreferrer" class="card-link">
            VER EN GITHUB <span class="arrow">→</span>
          </a>
        </div>
      ))
    }
  </div>
</div>

<style>
  .zone-pipeline-container {
    width: 100%;
    padding: 3rem 0;
  }

  .pipeline-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .pipeline-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  .pipeline-card {
    border: 1px dashed rgba(241, 233, 221, 0.15);
    background-color: rgba(241, 233, 221, 0.01);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .pipeline-card:hover {
    border-color: rgba(245, 158, 11, 0.35);
    background-color: rgba(245, 158, 11, 0.02);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .card-icon {
    font-size: 1.5rem;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .badge-in-progress {
    color: var(--color-amber);
    border: 1px solid rgba(245, 158, 11, 0.3);
    background-color: rgba(245, 158, 11, 0.05);
  }

  .badge-planned {
    color: var(--color-muted-2);
    border: 1px solid rgba(241, 233, 221, 0.12);
    background-color: rgba(241, 233, 221, 0.02);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-cream);
    margin: 0 0 0.75rem 0;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .card-desc {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-muted-2);
    margin: 0 0 2rem 0;
    flex-grow: 1;
  }

  .card-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--color-amber);
    text-decoration: none;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: fit-content;
    transition: opacity 0.2s ease;
  }

  .card-link:hover {
    opacity: 0.8;
  }

  .card-link:hover .arrow {
    transform: translateX(4px);
  }

  .arrow {
    transition: transform 0.2s ease;
  }
</style>
