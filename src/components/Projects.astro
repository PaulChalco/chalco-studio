---
import { getCollection } from "astro:content";
import Section from "./Section.astro";
import ProjectEntry from "./ProjectEntry.astro";
import Reveal from "./Reveal.astro";
import ZoneDivider from "./ZoneDivider.astro";
import ZoneShowreels from "./ZoneShowreels.astro";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => b.data.year - a.data.year);

const showreels = sortedProjects
  .filter(p => p.data.category === "Showreel")
  .sort((a, b) => {
    // ShowReel Publicidad (vimeoId 1155606625) va primero, Demo Reel Cine (1002577974) va segundo.
    if (a.data.vimeoId === "1155606625") return -1;
    if (b.data.vimeoId === "1155606625") return 1;
    return 0;
  });
const procesos = sortedProjects.filter(p => p.data.category !== "Showreel");
---

<Section id="proyectos" class="projects-section">
  <!-- Section Title -->
  <div class="section-header">
    <Reveal>
      <div class="section-label">// SELECTED_WORKS</div>
      <h2 class="section-title">PROYECTOS</h2>
    </Reveal>
  </div>

  <!-- ZONE 1: SHOWREELS -->
  <ZoneShowreels reels={showreels} />

  <!-- ZONE 2: PROCESO -->
  <div class="projects-zone">
    <ZoneDivider
      label="PROCESO"
      description="Cómo trabajo — simulación, procedural y render"
    />
    {procesos.length > 0 ? (
      <div class="projects-list">
        {procesos.map((project, idx) => (
          <ProjectEntry
            slug={project.id}
            title={project.data.title}
            year={project.data.year}
            category={project.data.category}
            tags={project.data.tags}
            description={project.data.description}
            vimeoId={project.data.vimeoId}
            vimeoHash={project.data.vimeoHash}
            thumbnail={project.data.thumbnail}
            featured={project.data.featured}
            status={project.data.status}
            index={idx}
          />
        ))}
      </div>
    ) : (
      <div class="coming-soon">// No projects available</div>
    )}
  </div>

  <!-- ZONE 3: PIPELINE / IA -->
  <div class="projects-zone">
    <ZoneDivider
      label="PIPELINE / IA"
      description="Hacia dónde voy — automatización y flujos con IA"
    />
    <div class="coming-soon">
      <p>// Próximamente</p>
    </div>
  </div>
</Section>

<style>
  .projects-section {
    background-color: var(--color-ink);
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .section-header {
    margin-bottom: 5rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    color: var(--color-amber);
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    color: var(--color-cream);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .projects-zone {
    margin-bottom: 6rem;
  }

  .projects-zone:last-child {
    margin-bottom: 0;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .coming-soon {
    padding: 3rem 0;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.15em;
    color: var(--color-muted-2);
    text-transform: uppercase;
    border-top: 1px dashed rgba(241, 233, 221, 0.08);
  }

  .coming-soon p {
    margin: 0;
  }
</style>
