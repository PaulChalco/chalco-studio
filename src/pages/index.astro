---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
---

<Layout title="Chalco Studio · VFX + AI" description="Sitio oficial de Chalco Studio. Creando en la intersección de VFX y AI.">
  <main>
    <!-- Placeholder para visualizar el scroll y la respuesta del Nav / Footer -->
    <Section id="scroll-placeholder">
      <div class="placeholder-content">
        <p>// CHALCO_STUDIO FRAMEWORK INSTALLED</p>
        <p class="desc">Nav, footer, film grain, ambient leaks, and motion engine are active. Hero section placeholder.</p>
      </div>
    </Section>
  </main>
</Layout>

<style>
  .placeholder-content {
    min-height: 140vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border: 1px dashed var(--color-dim-2);
    border-radius: 8px;
    font-family: var(--font-mono);
    color: var(--color-muted);
    font-size: 14px;
    letter-spacing: 0.05em;
    text-align: center;
    padding: 2rem;
  }

  .desc {
    margin-top: 1rem;
    color: var(--color-dim);
    font-size: 12px;
    max-width: 400px;
  }
</style>
